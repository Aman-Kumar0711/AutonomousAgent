# =============================================================================
# Autonomous Lead Generation Agent - Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- SerpAPI (Required for scraping) ---
# Sign up at https://serpapi.com (100 free searches/month)
SERPAPI_KEY=your_serpapi_key_here

# --- Google PageSpeed Insights (Optional, free) ---
# Get a key at https://developers.google.com/speed/docs/insights/v5/get-started
# Works without a key but with lower rate limits
PAGESPEED_API_KEY=

# --- Email: Gmail SMTP ---
# Enable "App Passwords" at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=amanchahar175@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here
FROM_EMAIL=amanchahar175@gmail.com
FROM_NAME=Aman Kumar

# --- Email: Resend API (Optional alternative — better deliverability) ---
# Sign up at https://resend.com (free tier: 3000 emails/month)
# If RESEND_API_KEY is set and SMTP_USER is empty, Resend is used
RESEND_API_KEY=

# --- Your Info (shown in emails & portfolio) ---
YOUR_NAME=Aman Kumar
YOUR_EMAIL=amanchahar175@gmail.com

# --- Portfolio Dashboard URL ---
# After deploying to Vercel, put your URL here
PORTFOLIO_BASE_URL=https://your-app.vercel.app

# --- Agent Settings ---
SCRAPE_DELAY=2.0
MAX_RESULTS_PER_QUERY=20
